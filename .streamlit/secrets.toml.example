[connections.gsheets]
type = "gsheets"
spreadsheet = "1dt0pOubE8FAxnUGn6I3BYRnp_9pWpeA3uWiEk1oZfDM"

# Uncomment dan isi bagian di bawah jika menggunakan Service Account
# Dapatkan JSON key dari Google Cloud Console

# [connections.gsheets.gcp_service_account]
# type = "service_account"
# project_id = "YOUR_PROJECT_ID"
# private_key_id = "YOUR_PRIVATE_KEY_ID"
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "YOUR_SERVICE_ACCOUNT_EMAIL@YOUR_PROJECT.iam.gserviceaccount.com"
# client_id = "YOUR_CLIENT_ID"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "YOUR_CERT_URL"

# Optional untuk modul Replacement Narasi.
# Bisa juga memakai HUGGINGFACE_API_KEY = "hf_your_token_here" di root secrets.
# [huggingface]
# api_token = "hf_your_token_here"

# Optional untuk generate data sintetis ATS dengan Gemini.
# Bisa juga memakai GEMINI_API_KEY = "your_key_here" di root secrets.
# [gemini]
# api_key = "your_key_here"
